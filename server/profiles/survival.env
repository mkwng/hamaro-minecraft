# Profile: survival — the default family world.
# This file is mastered in S3 (profiles/survival/profile.env); the admin website
# edits it there. Any itzg/minecraft-server env var works here:
# https://docker-minecraft-server.readthedocs.io/
TYPE=PAPER
VERSION=26.2
MEMORY=6G
MOTD=Hamaro Family Server §a(Hazel + Marlowe + Rowan)
DIFFICULTY=easy
MODE=survival
VIEW_DISTANCE=12
SPAWN_PROTECTION=0

# Security: only listed accounts can join. Manage via the website (Players tab).
ENABLE_WHITELIST=TRUE
ENFORCE_WHITELIST=TRUE
EXISTING_WHITELIST_FILE=SYNCHRONIZE
WHITELIST=
EXISTING_OPS_FILE=SYNCHRONIZE
OPS=
