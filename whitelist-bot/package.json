{
  "name": "hamaro-whitelist-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord /whitelist bot: self-service Minecraft whitelisting via Microsoft OAuth + RCON",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "register-commands": "node dist/registerCommands.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1095.0",
    "@aws-sdk/client-ssm": "^3.1095.0",
    "@azure/msal-node": "^5.4.2",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "rcon-client": "^4.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "eslint": "^10.8.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
