# Copy to .env and fill in. See README.md for where each value comes from.
# Secrets (DISCORD_TOKEN, AZURE_CLIENT_SECRET, RCON_PASSWORD) are set on the
# host at deploy time — never commit a filled-in .env.

# --- Discord (Developer Portal -> your application) ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=123456789012345678
# Optional: register slash commands to a guild (server) so they appear instantly.
# Leave empty to register globally (can take up to an hour to show up).
DISCORD_GUILD_ID=
# Optional: role ID allowed to run /invite (besides members with Manage Server).
ADMIN_ROLE_ID=
# Optional: "Join our Discord" link shown on the success page for people invited
# via /invite who aren't in the server yet.
DISCORD_INVITE_URL=https://discord.gg/73K2NaWXmT

# --- Azure app registration ("Personal Microsoft accounts only") ---
# Client IDs are not secret (they appear in every login URL).
AZURE_CLIENT_ID=d364007e-61ae-4a85-a09a-56f83b4691bd
# Set on the host at deploy time (Azure -> Certificates & secrets -> value).
AZURE_CLIENT_SECRET=
# Must exactly match a Web redirect URI configured in Azure (https required
# except for http://localhost, which is handy for a dev run).
OAUTH_REDIRECT_URI=https://hamaro.rowan.wang/auth/callback
# Optional: base URL used in invite links. Defaults to the origin of OAUTH_REDIRECT_URI
# (here: https://hamaro.rowan.wang).
PUBLIC_BASE_URL=

# Optional (defense in depth): shared secret CloudFront adds as the
# X-Origin-Verify header; when set, /invite and /auth/* refuse requests without
# it so the origin can't be hit around the CDN. Same value as
# `cdk deploy -c botOriginVerifySecret=...`. Set on the host, never committed.
ORIGIN_VERIFY_SECRET=

# --- Paper server RCON (same box; 25575 published on 127.0.0.1 only, never publicly) ---
RCON_HOST=127.0.0.1          # boot.sh publishes hamaro-mc's RCON on the host loopback
RCON_PORT=25575
# Must equal RCON_PASSWORD in the active profile's profile.env (set it there via
# the control panel Settings raw editor so it's stable across restarts).
RCON_PASSWORD=
# Address shown to players on the success page.
MC_SERVER_ADDRESS=mc.rowan.wang

# --- Durable whitelist (recommended for this repo's setup) ---
# The MC profile uses EXISTING_WHITELIST_FILE=SYNCHRONIZE, so whitelist.json is
# rebuilt from the profile's WHITELIST= line in S3 on every server start; an
# RCON-only add would be lost. With HAMARO_BUCKET set, adds are also written to
# s3://<bucket>/profiles/<active>/profile.env (like the control panel does).
# Bucket name = the game stack's data bucket (see docs/RUNBOOK.md / CFN outputs).
HAMARO_BUCKET=
AWS_REGION=us-west-2
# Optional: pin the profile name; otherwise read from this SSM parameter.
HAMARO_ACTIVE_PROFILE=
HAMARO_ACTIVE_PROFILE_PARAM=/hamaro/active-profile

# --- Bot behaviour ---
PORT=3000
INVITE_TTL_MINUTES=15
# true = start the web server + validate config, but skip Discord login, RCON and S3.
DRY_RUN=false
