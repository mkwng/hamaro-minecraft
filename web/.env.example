# Vite build-time env (only VITE_* vars are exposed to the page).
# Copy to .env.production (or .env.production.local) before `npm run build`.
#
# Public Discord invite link. When set, the home page shows a "Join our Discord"
# button next to the world-map link; when empty/unset the button is hidden.
VITE_DISCORD_INVITE_URL=https://discord.gg/73K2NaWXmT

# Whitelist bot base URL for the dashboard's "Generate invite link" control
# (POST /admin/invite). Empty in production: the bot is served same-origin under
# /admin/* by CloudFront. Set for local dev, e.g. http://localhost:3000
VITE_WHITELIST_BOT_BASE=
